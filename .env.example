# =============================================================================
# Karmik Matris Analizi — Environment Variables
# =============================================================================
# Bu dosyayı .env olarak kopyalayıp gerçek değerleri yazın.
# Vercel'de: vercel env add <ANAHTAR>

# -----------------------------------------------------------------------------
# Anthropic Claude API Key
# https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...

# -----------------------------------------------------------------------------
# Supabase
# https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
# DİKKAT: SERVICE_KEY tüm RLS'i bypass eder. Sadece backend (api/) kullanır.
# ASLA frontend kodunda kullanmayın!
SUPABASE_SERVICE_KEY=eyJ...
